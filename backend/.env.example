# ──────────────────────────────────────────────────────────────
# Stress Less — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env
# .env dosyasını asla git'e commit etme!
# ──────────────────────────────────────────────────────────────

# Veritabanı
# Railway PostgreSQL: otomatik atanır (DATABASE_URL env var olarak gelir)
# Lokal Docker: aşağıdaki varsayılanı kullan
DATABASE_URL=postgresql+psycopg://ppguser:ppgpass@db:5432/ppgdb

# JWT — en az 32 karakter, güçlü rastgele string
# Üret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_GUCLU_SECRET_KEY_YAZ

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin hesapları (virgülle ayır)
ADMIN_EMAILS=admin@sirket.com,diger@sirket.com

# Google Gemini API
# https://aistudio.google.com adresinden al
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# Ortam: development veya production
ENVIRONMENT=development

# CORS — production'da Railway URL'ini yaz
# Örn: https://ppg-api.railway.app,https://stress-less.vercel.app
ALLOWED_ORIGINS=*
